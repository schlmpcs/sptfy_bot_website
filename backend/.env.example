# ── Database (same credentials as the Telegram bot) ──────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_DATABASE=spotify_bot
# Use "require" on production, "disable" for local dev
DB_SSL_MODE=disable

# ── Bot pricing (kept in sync with the Telegram bot's .env) ──────────────────
BOT_DEFAULT_PAYMENT_PRICE=700   # KZ group plan, ₸/month
BOT_RU_PAYMENT_PRICE=200        # RU group plan, ₽/month
BOT_RU_INDIVIDUAL_PRICE=250     # RU individual plan, ₽/month
BOT_RU_DUO_PRICE=600            # RU duo plan, ₽/month
BOT_SUPPORT_USERNAME=sptfy_premium

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:5173
